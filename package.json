{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:engine & npm run dev:web",
    "dev:engine": "npm --workspace=packages/engine run dev",
    "dev:web": "npm --workspace=packages/web run dev",
    "build": "npm --workspace=packages/engine run build && npm --workspace=packages/web run build",
    "build:engine": "npm --workspace=packages/engine run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "potrace": "^2.1.8"
  },
  "devDependencies": {
    "@types/potrace": "^2.1.5"
  }
}
